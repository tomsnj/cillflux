# yaml-language-server: $schema=https://raw.githubusercontent.com/bjw-s-labs/helm-charts/main/charts/other/app-template/schemas/helmrelease-helm-v2.schema.json
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  annotations:
    patch.sko.ai/app-template: common
  name: vaultwarden
spec:
  chart:
    spec:
      chart: app-template
      sourceRef:
        kind: HelmRepository
        name: bjw-s-labs
        namespace: flux-system
      version: 4.6.2
  interval: 12h
  install:
    remediation:
      retries: 3
  upgrade:
    cleanupOnFail: true
    remediation:
      strategy: rollback
      retries: 3
  dependsOn:
    - name: local-path-provisioner
      namespace: storage
  values:
    controllers:
      vaultwarden:
        annotations:
          reloader.stakater.com/auto: "true"
        containers:
          app:
            image:
              repository: ghcr.io/dani-garcia/vaultwarden
              tag: 1.35.7@sha256:9a8eec71f4a52411cc43edc7a50f33e9b6f62b5baca0dd95f0c6e7fd60f1a341
            env:
              DOMAIN: "https://kumar.gs-farm.net"
              ADMIN_TOKEN:
                valueFrom:
                  secretKeyRef:
                    name: vw-secret
                    key: admin-token
              SSO_ENABLED: "true"
              SSO_CLIENT_ID: "vaultwarden"
              SSO_CLIENT_SECRET:
                valueFrom:
                  secretKeyRef:
                    name: vw-secret
                    key: SSO_CLIENT_SECRET
              SSO_AUTHORITY: "https://elvis.gs-farm.net/realms/master"
              SSO_SCOPES: "email profile"
              SSO_PKCE_ENABLED: "true"
              ROCKET_SECRET_KEY:
                valueFrom:
                  secretKeyRef:
                    name: vw-secret
                    key: ROCKET_SECRET_KEY
            probes:
              liveness:
                enabled: true
              readiness:
                enabled: true
            resources:
              limits:
                memory: 100Mi
              requests:
                cpu: 100m
                memory: 100Mi

    admin:
      enabled: true
      disableAdminToken: false
      existingSecret: vw-secret

    smtp:
      enabled: true
      host: smtp.gmail.com
      from: "tfs05jhu@gmail.com"
      fromName: "Tom Steck"
      security: starttls
      port: 587
      existingSecret: vw-secret

    persistence:
      config:
        enabled: true
        type: persistentVolumeClaim
        size: 5Gi
        accessMode: ReadWriteOnce
        storageClass: gsks0
      data:
        enabled: true
        type: persistentVolumeClaim
        size: 5Gi
        accessMode: ReadWriteOnce
        storageClass: gsks0

    service:
      app:
        controller: vaultwarden
        ports:
          http:
            port: 80
          websocket:
            enabled: true
            port: 3012
